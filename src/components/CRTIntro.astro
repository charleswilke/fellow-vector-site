---
// CRT Intro — boot sequence overlay
// Plays on first load per session, then dismissed
---

<div id="crt-intro" role="presentation">
  <div id="crt-screen">
    <pre id="crt-text" aria-live="polite"></pre>
    <div id="crt-prompt">[ press any key or click to skip ]</div>
  </div>
</div>
<canvas id="fv-dissolve"></canvas>

<style>
  #crt-intro {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: rise 0.8s ease forwards;
  }

  @keyframes rise {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  #crt-screen {
    width: min(600px, 90vw);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  #crt-text {
    font-family: 'VT323', monospace;
    font-size: clamp(1.1rem, 2.8vw, 1.55rem);
    color: #00ff88;
    text-shadow: 0 0 8px rgba(57, 255, 20, 0.85), 0 0 24px rgba(57, 255, 20, 0.3);
    line-height: 1.65;
    white-space: pre;
    min-height: 16rem;
  }

  #crt-prompt {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: rgba(57, 255, 20, 0.45);
    animation: blink 1.4s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  #fv-dissolve {
    position: fixed;
    inset: 0;
    z-index: 100000;
    display: none;
    pointer-events: none;
    image-rendering: pixelated;
  }
</style>

<script>
  (function () {
    const SEEN_KEY    = 'fv_intro_seen';
    const EXPIRY_DAYS = 30;

    const introEl    = document.getElementById('crt-intro') as HTMLElement;
    const screenEl   = document.getElementById('crt-screen') as HTMLElement;
    const textEl     = document.getElementById('crt-text') as HTMLElement;
    const dissolveEl = document.getElementById('fv-dissolve') as HTMLCanvasElement;

    if (!introEl || !screenEl || !textEl || !dissolveEl) return;

    // Skip if already seen within the expiry window
    const stored = localStorage.getItem(SEEN_KEY);
    if (stored && Date.now() < Number(stored)) {
      introEl.style.display = 'none';
      return;
    }

    let dismissed = false;

    const wait = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

    // ── Boot sequence lines ──
    const BOOT = [
      'FELLOW VECTOR  //  SIGNAL ACQUIRED',
      '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━',
      '',
      '>> initializing carrier wave...',
      '>> scanning for signal source...',
      '>> carrier detected',
      '>> authenticating transmission...',
      '>> decoding...',
      '',
      'CONNECTION ESTABLISHED.',
      '',
      'WELCOME.',
    ];

    async function typeAll() {
      for (const line of BOOT) {
        if (dismissed) return;
        await typeLine(line);
        textEl.textContent += '\n';
        const pause = line === '' ? 80 : line.startsWith('>>') ? 200 : 340;
        await wait(pause);
      }
    }

    function typeLine(line: string): Promise<void> {
      return new Promise(resolve => {
        if (line === '') { resolve(); return; }
        let i = 0;
        const speed = line.startsWith('━') ? 12 : 32;
        const iv = setInterval(() => {
          if (dismissed) { clearInterval(iv); resolve(); return; }
          textEl.textContent += line[i++];
          if (i >= line.length) { clearInterval(iv); resolve(); }
        }, speed);
      });
    }

    // ── Pixel dissolve ──
    function runDissolve() {
      const W = dissolveEl.width  = window.innerWidth;
      const H = dissolveEl.height = window.innerHeight;
      const ctx = dissolveEl.getContext('2d')!;

      const BLOCK    = 2;
      const cols     = Math.ceil(W / BLOCK);
      const rows     = Math.ceil(H / BLOCK);
      const total    = cols * rows;
      const DURATION = 700;

      // Fill black + show canvas synchronously — covers intro in same paint
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, W, H);
      dissolveEl.style.display = 'block';
      introEl.style.display = 'none';

      // Shuffle block order (Fisher-Yates)
      const order = new Uint32Array(total);
      for (let i = 0; i < total; i++) order[i] = i;
      for (let i = total - 1; i > 0; i--) {
        const j = (Math.random() * (i + 1)) | 0;
        const tmp = order[i]; order[i] = order[j]; order[j] = tmp;
      }

      // Pre-clear ~15% of blocks so the first visible frame already has holes in it
      const preCleared = (total * 0.15) | 0;
      for (let i = 0; i < preCleared; i++) {
        const idx = order[i];
        ctx.clearRect((idx % cols) * BLOCK, ((idx / cols) | 0) * BLOCK, BLOCK, BLOCK);
      }

      let prevCleared = preCleared;
      const start = performance.now();

      function frame(now: number) {
        const t      = Math.min((now - start) / DURATION, 1);
        // ease-out: site appears quickly, remaining blocks linger
        const eased   = 1 - (1 - t) * (1 - t);
        const cleared = (preCleared + eased * (total - preCleared)) | 0;

        for (let i = prevCleared; i < cleared; i++) {
          const idx = order[i];
          ctx.clearRect((idx % cols) * BLOCK, ((idx / cols) | 0) * BLOCK, BLOCK, BLOCK);
        }
        prevCleared = cleared;

        if (t < 1) {
          requestAnimationFrame(frame);
        } else {
          dissolveEl.style.display = 'none';
        }
      }

      requestAnimationFrame(frame);
    }

    // ── Dismiss ──
    function dismiss() {
      if (dismissed) return;
      dismissed = true;
      const expiry = Date.now() + EXPIRY_DAYS * 24 * 60 * 60 * 1000;
      localStorage.setItem(SEEN_KEY, String(expiry));
      runDissolve();
    }

    // ── Start — rise from black, then show text ──
    setTimeout(async () => {
      if (dismissed) return;
      screenEl.style.opacity = '1';
      await typeAll();
      if (dismissed) return;
      await wait(1600);
      dismiss();
    }, 900);

    document.addEventListener('click',     dismiss, { once: true });
    document.addEventListener('keydown',   dismiss, { once: true });
    introEl.addEventListener('touchstart', dismiss, { once: true, passive: true });
  })();
</script>
