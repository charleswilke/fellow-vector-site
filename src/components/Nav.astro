---
const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/about',    label: 'About'    },
  { href: '/book',     label: 'Book a Call' },
];

const { pathname } = Astro.url;
---

<header id="site-nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="Fellow Vector home">
      <span class="logo-bracket">[</span>
      <span class="logo-text">FELLOW VECTOR</span>
      <span class="logo-bracket">]</span>
    </a>

    <nav aria-label="Main navigation">
      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: pathname.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 8000;
    background: rgba(8, 9, 15, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--sp-lg);
  }

  /* Logo */
  .nav-logo {
    font-family: var(--font-crt);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--fg);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 2px;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .nav-logo:hover {
    color: var(--phosphor);
    text-shadow: var(--glow-green);
  }

  .logo-bracket {
    color: var(--phosphor);
    opacity: 0.6;
  }

  .logo-text {
    margin: 0 2px;
  }

  /* Links */
  nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--sp-lg);
  }

  .nav-link {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.2s, text-shadow 0.2s;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--phosphor);
    transition: width 0.25s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--phosphor);
    text-shadow: var(--glow-green);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-sm);
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--fg-muted);
    transition: all 0.2s;
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      padding: var(--sp-lg);
    }

    nav.open {
      display: block;
    }

    nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-md);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const nav    = document.querySelector('#site-nav nav') as HTMLElement;

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
