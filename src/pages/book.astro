---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Call"
  description="Schedule a call with Fellow Vector to discuss consulting, speaking, or webinar engagements."
>

  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true">
      <img src="/book.jpg" alt="" class="page-hero-splash" />
    </div>
    <div class="container page-hero-inner">
      <div class="label">// establish connection</div>
      <h1>Book a Call</h1>
      <p class="text-muted page-hero-sub">
        Ready to engage or just exploring? This is where we start.
        Pick a time. Let's talk.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container booking-layout">

      <div class="booking-sidebar">
        <div class="booking-info-block">
          <div class="label">// what to expect</div>
          <p>
            A 30-minute exploratory call. No pitch, no pressure. We'll talk about where you are,
            what you're trying to figure out, and whether Fellow Vector can help.
          </p>
        </div>

        <div class="booking-info-block">
          <div class="label">// prefer email?</div>
          <a href="mailto:cwilke@fellowvector.com" class="email-link">cwilke@fellowvector.com</a>
        </div>

        <div class="booking-info-block">
          <div class="label">// good fits</div>
          <ul class="info-list">
            <li>You're navigating AI adoption and need a thinking partner</li>
            <li>You're looking for a speaker for an upcoming event</li>
            <li>You want to bring a webinar or workshop to your team</li>
            <li>You're not sure what you need... but you know you need something</li>
          </ul>
        </div>
      </div>

      <!-- ── Cal.com embed ── -->
      <div class="booking-embed-wrap">
        <div class="embed-frame">
          <div class="embed-corner tl"></div>
          <div class="embed-corner tr"></div>
          <div class="embed-corner bl"></div>
          <div class="embed-corner br"></div>
          <div class="embed-scanlines" aria-hidden="true"></div>
          <div id="cal-embed"></div>
        </div>
      </div>

    </div>
  </section>

  <script type="text/javascript">
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });

    Cal("inline", {
      elementOrSelector: "#cal-embed",
      calLink: "cwilke/discovery-call",
      config: {
        layout: "month_view",
        theme: "dark",
        brandColor: "#00ff88",
      }
    });

    // Remove scrollbar from Cal.com iframe once it's injected
    const observer = new MutationObserver(() => {
      const iframe = document.querySelector("#cal-embed iframe");
      if (iframe) {
        iframe.setAttribute("scrolling", "no");
        observer.disconnect();
      }
    });
    observer.observe(document.getElementById("cal-embed"), { childList: true, subtree: true });
  </script>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    border-bottom: 1px solid var(--border);
    padding: var(--sp-2xl) 0 var(--sp-xl);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-hero-splash {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    opacity: 0.45;
  }

  .page-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,
        var(--bg) 20%,
        rgba(8, 9, 15, 0.7) 55%,
        rgba(8, 9, 15, 0.25) 100%
      ),
      linear-gradient(to top,
        var(--bg) 0%,
        transparent 35%
      );
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .page-hero-inner h1 { margin-top: var(--sp-xs); margin-bottom: var(--sp-sm); }

  .page-hero-sub {
    font-size: 1rem;
    max-width: 52ch;
  }

  .booking-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--sp-2xl);
    align-items: start;
  }

  .booking-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xl);
    position: sticky;
    top: 80px;
  }

  .booking-info-block {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .booking-info-block p {
    font-size: 0.9rem;
    color: var(--fg-muted);
  }

  .email-link {
    font-size: 0.85rem;
    color: var(--phosphor);
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
  }

  .email-link:hover { opacity: 0.7; }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .info-list li {
    font-size: 0.85rem;
    color: var(--fg-muted);
    padding-left: var(--sp-md);
    border-left: 1px solid var(--border);
    line-height: 1.5;
  }

  /* Embed area */
  .booking-embed-wrap {
    min-height: 600px;
  }

  .embed-frame {
    position: relative;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    overflow: hidden;
  }

  /* Corner brackets */
  .embed-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 2;
    pointer-events: none;
  }

  .embed-corner.tl { top: -1px; left: -1px; border-top: 2px solid var(--phosphor); border-left: 2px solid var(--phosphor); }
  .embed-corner.tr { top: -1px; right: -1px; border-top: 2px solid var(--phosphor); border-right: 2px solid var(--phosphor); }
  .embed-corner.bl { bottom: -1px; left: -1px; border-bottom: 2px solid var(--phosphor); border-left: 2px solid var(--phosphor); }
  .embed-corner.br { bottom: -1px; right: -1px; border-bottom: 2px solid var(--phosphor); border-right: 2px solid var(--phosphor); }

  /* Scanline overlay */
  .embed-scanlines {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.08) 3px,
      rgba(0, 0, 0, 0.08) 4px
    );
  }

  #cal-embed {
    position: relative;
    width: 100%;
    min-height: 600px;
  }

  @media (max-width: 768px) {
    .booking-layout {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
    }

    .booking-sidebar { position: static; }
  }
</style>
