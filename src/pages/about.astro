---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SubstackFeed from '../components/SubstackFeed.astro';
---

<BaseLayout
  title="About"
  description="Charles Wilke is a writer, designer, and generative AI consultant helping small and mid-sized businesses make practical, grounded use of emerging technology."
>

  <PageHero label="// about the operator" title="Charles Wilke" image="/about.webp">
    <p class="page-hero-sub text-muted">Writer. Designer. Generative AI Consultant.</p>
  </PageHero>

  <section class="section">
    <div class="container about-grid">

      <div class="about-body">

        <div class="about-intro">
          <!-- Portrait shown inline on mobile, floated right -->
          <div class="portrait-wrap portrait-mobile" aria-hidden="true">
            <div class="portrait-glitch-container">
              <span class="corner tl"></span>
              <span class="corner tr"></span>
              <span class="corner bl"></span>
              <span class="corner br"></span>
              <img src="/cw4.webp" alt="Charles Wilke" class="portrait-img" width="1254" height="1254" />
              <img src="/cw2.webp" alt="" class="portrait-reveal" aria-hidden="true" width="800" height="800" />
              <div class="glitch-slice s1"></div>
              <div class="glitch-slice s2"></div>
              <div class="glitch-slice s3"></div>
              <div class="portrait-scanlines" aria-hidden="true"></div>
            </div>
            <div class="portrait-label">// charles</div>
          </div>

          <p>
            In my day-to-day, I'm the architect of <a href="https://pos.toasttab.com/news/toast-expands-toast-iq-smart-ai-assistant" target="_blank" rel="noopener">Toast IQ</a>'s soul. A senior product designer and proud parent of Toast's first steps into this brave new world.
          </p>

        </div>

        <p>
          Before that, I spent years making games at Insomniac and crafting content for product at GoDaddy.
          Roles that taught me how technology lands when real people have to use it every day.
        </p>

        <p>
          Through Fellow Vector, I partner with organizations to translate AI from an abstract trend into
          a usable capability. 
        </p>
        <p>
          That might mean shaping content strategies, designing AI-assisted workflows,
          building custom tools, or leading workshops that help teams understand how these systems can
          support their real goals.
        </p>

        <p class="about-lead">
          I help small and mid-sized businesses make practical, grounded use of this emerging
          technology. Not for efficiency's sake, but to reclaim time for the work that
          actually brings them joy.
        </p>
        <p class="about-lead">
          I do this with less hype and a clear sense of what actually
          matters for our best work to effortlessly flow from us.
        </p>
        <p>
          My approach is collaborative and human-centered.
        </p>
        <p>
          I believe these tools should shorten the distance between you and the things you care about most.
        </p>
        <p>
          Your craft, your people, your next meaningful thing.
        </p>

        <p>
          Let's skip the trite "what can AI do" conversation. The better question is: what's keeping
          you from your joy? What would you build, explore, or finally get to if the tedious stuff
          just... took less time? That's where we start.
        </p>

        <a href="/book" class="btn btn-primary" style="margin-top: 1rem;">Book a Call with Charles</a>

        <hr class="divider" />

        <p class="text-muted" style="font-size: 0.9rem;">
          If you want to see what happens when this brain isn't consulting, check out the games,
          albums, Substack series, and other strange artifacts at my personal site!
        </p>
        <a href="https://charleswilke.com" target="_blank" rel="noopener" class="btn btn-ghost">charleswilke.com</a>
      </div>

      <aside class="about-sidebar">

        <!-- Portrait -->
        <div class="portrait-wrap portrait-sidebar">
          <div class="portrait-glitch-container">
            <span class="corner tl"></span>
            <span class="corner tr"></span>
            <span class="corner bl"></span>
            <span class="corner br"></span>
            <img src="/cw4.webp" alt="Charles Wilke" class="portrait-img" width="1254" height="1254" loading="lazy" />
            <img src="/cw2.webp" alt="" class="portrait-reveal" aria-hidden="true" width="800" height="800" loading="lazy" />
            <div class="glitch-slice s1"></div>
            <div class="glitch-slice s2"></div>
            <div class="glitch-slice s3"></div>
            <div class="portrait-scanlines" aria-hidden="true"></div>
          </div>
          <div class="portrait-label">// charles</div>
        </div>

        <div class="sidebar-block">
          <div class="label">// works with</div>
          <ul class="sidebar-list">
            <li>Small & mid-sized businesses</li>
            <li>Founders & operators</li>
            <li>Executive teams</li>
            <li>Associations & communities</li>
            <li>Conference organizers</li>
          </ul>
        </div>

        <div class="sidebar-block">
          <div class="label">// disciplines</div>
          <ul class="sidebar-list">
            <li>Generative AI consulting</li>
            <li>Content strategy</li>
            <li>AI-assisted workflow design</li>
            <li>Custom tool development</li>
            <li>Workshops & speaking</li>
          </ul>
        </div>

        <div class="sidebar-block">
          <div class="label">// contact</div>
          <a href="/book" class="sidebar-link">Book a call →</a>
          <a href="mailto:cwilke@fellowvector.com" class="sidebar-link">Send an email →</a>
        </div>

        <div class="sidebar-block">
          <div class="label">// fellow vector is</div>
          <p class="sidebar-note">
            Just Charles. One consultant, fully present in every engagement.<br />No handoffs, no junior staff.<br />You work with me directly.
          </p>
        </div>

        <div class="sidebar-block">
          <div class="label">// recently on exploring l.ai.bor</div>
          <SubstackFeed limit={3} />
          <a href="/writing" class="sidebar-link" style="margin-top: var(--sp-xs);">Explore more →</a>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>

<style>
  .page-hero-sub {
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* ── Portrait ── */
  .portrait-wrap {
    position: relative;
  }

  .portrait-glitch-container {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--phosphor-dim);
  }

  .portrait-img {
    display: block;
    width: 100%;
    height: auto;
    position: relative;
    z-index: 1;
  }

  /* Real photo underneath, always visible */
  .portrait-reveal {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 1;
  }

  /* Glitch slices: horizontal bands that reveal the photo */
  .glitch-slice {
    position: absolute;
    left: 0;
    width: 100%;
    z-index: 2;
    background-image: url('/cw2.webp');
    background-size: 100% auto;
    background-repeat: no-repeat;
    opacity: 0;
    pointer-events: none;
    mix-blend-mode: normal;
  }

  .glitch-slice.s1 {
    top: 15%;
    height: 12%;
    background-position: 0 15%;
  }
  .glitch-slice.s2 {
    top: 45%;
    height: 8%;
    background-position: 0 45%;
  }
  .glitch-slice.s3 {
    top: 72%;
    height: 15%;
    background-position: 0 72%;
  }

  /* Glitch runs by default, cursor pointer for click-to-flip */
  .portrait-glitch-container {
    cursor: pointer;
  }

  .portrait-img {
    animation: glitch-flicker 12s steps(2) infinite;
  }

  .portrait-reveal {
    animation: reveal-flash 18s steps(1) infinite;
  }

  .glitch-slice.s1 {
    animation: slice-glitch-1 16s steps(1) infinite;
  }
  .glitch-slice.s2 {
    animation: slice-glitch-2 20s steps(1) infinite;
  }
  .glitch-slice.s3 {
    animation: slice-glitch-3 14s steps(1) infinite;
  }

  /* Hover: horizontal band that follows cursor — stepped/pixelated edges */
  .portrait-wrap:hover .portrait-img {
    --band-center: var(--my, 50%);
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      black calc(var(--band-center) - 28%),
      rgba(0,0,0,0.85) calc(var(--band-center) - 28%),
      rgba(0,0,0,0.85) calc(var(--band-center) - 24%),
      rgba(0,0,0,0.6) calc(var(--band-center) - 24%),
      rgba(0,0,0,0.6) calc(var(--band-center) - 20%),
      rgba(0,0,0,0.3) calc(var(--band-center) - 20%),
      rgba(0,0,0,0.3) calc(var(--band-center) - 16%),
      transparent calc(var(--band-center) - 16%),
      transparent calc(var(--band-center) + 16%),
      rgba(0,0,0,0.3) calc(var(--band-center) + 16%),
      rgba(0,0,0,0.3) calc(var(--band-center) + 20%),
      rgba(0,0,0,0.6) calc(var(--band-center) + 20%),
      rgba(0,0,0,0.6) calc(var(--band-center) + 24%),
      rgba(0,0,0,0.85) calc(var(--band-center) + 24%),
      rgba(0,0,0,0.85) calc(var(--band-center) + 28%),
      black calc(var(--band-center) + 28%),
      black 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black calc(var(--band-center) - 28%),
      rgba(0,0,0,0.85) calc(var(--band-center) - 28%),
      rgba(0,0,0,0.85) calc(var(--band-center) - 24%),
      rgba(0,0,0,0.6) calc(var(--band-center) - 24%),
      rgba(0,0,0,0.6) calc(var(--band-center) - 20%),
      rgba(0,0,0,0.3) calc(var(--band-center) - 20%),
      rgba(0,0,0,0.3) calc(var(--band-center) - 16%),
      transparent calc(var(--band-center) - 16%),
      transparent calc(var(--band-center) + 16%),
      rgba(0,0,0,0.3) calc(var(--band-center) + 16%),
      rgba(0,0,0,0.3) calc(var(--band-center) + 20%),
      rgba(0,0,0,0.6) calc(var(--band-center) + 20%),
      rgba(0,0,0,0.6) calc(var(--band-center) + 24%),
      rgba(0,0,0,0.85) calc(var(--band-center) + 24%),
      rgba(0,0,0,0.85) calc(var(--band-center) + 28%),
      black calc(var(--band-center) + 28%),
      black 100%
    );
  }
  .portrait-wrap:hover .portrait-reveal {
    animation: none;
    opacity: 1;
  }
  .portrait-wrap:hover .glitch-slice {
    animation: none;
    opacity: 0;
  }

  /* Flip animation on the container */
  .portrait-glitch-container {
    transition: transform 0.3s ease;
  }

  .portrait-wrap.flipping .portrait-glitch-container {
    transform: scaleX(0);
  }

  /* Flipped state: show real photo, hide drawn */
  .portrait-wrap.flipped .portrait-img {
    opacity: 0;
    animation: none;
    -webkit-mask-image: none;
    mask-image: none;
  }
  .portrait-wrap.flipped .portrait-reveal {
    opacity: 1;
    animation: none;
  }
  .portrait-wrap.flipped .glitch-slice {
    animation: none;
    opacity: 0;
  }

  /* Flipped hover: just show the photo clean */
  .portrait-wrap.flipped:hover .portrait-img {
    opacity: 0;
    -webkit-mask-image: none;
    mask-image: none;
  }
  .portrait-wrap.flipped:hover .portrait-reveal {
    opacity: 1;
  }

  @keyframes glitch-flicker {
    0%   { opacity: 1; }
    94%  { opacity: 1; }
    94.5%{ opacity: 0.7; transform: translateX(2px); }
    95.5%{ opacity: 1; transform: translateX(0); }
    97%  { opacity: 1; }
    97.5%{ opacity: 0.85; transform: translateX(-1px); }
    98%  { opacity: 1; transform: translateX(0); }
  }

  @keyframes reveal-flash {
    0%   { opacity: 0; }
    92%  { opacity: 0; }
    92.5%{ opacity: 1; }
    94%  { opacity: 1; }
    94.5%{ opacity: 0; }
  }

  @keyframes slice-glitch-1 {
    0%   { opacity: 0; transform: translateX(0); }
    93%  { opacity: 0; }
    93.5%{ opacity: 1; transform: translateX(-4px); }
    94.5%{ opacity: 1; transform: translateX(6px); }
    95%  { opacity: 0; transform: translateX(0); }
  }

  @keyframes slice-glitch-2 {
    0%   { opacity: 0; transform: translateX(0); }
    91%  { opacity: 0; }
    91.5%{ opacity: 1; transform: translateX(8px); }
    92.5%{ opacity: 1; transform: translateX(-3px); }
    93%  { opacity: 0; transform: translateX(0); }
  }

  @keyframes slice-glitch-3 {
    0%   { opacity: 0; transform: translateX(0); }
    95%  { opacity: 0; }
    95.5%{ opacity: 1; transform: translateX(-6px); }
    96.5%{ opacity: 0; transform: translateX(0); }
  }

  .portrait-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      transparent 35%,
      rgba(8, 9, 15, 0.7) 75%,
      rgba(8, 9, 15, 0.92) 100%
    );
    pointer-events: none;
  }

  .portrait-label {
    margin-top: -1px;
    padding: 0.4rem 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-align: center;
    border: 1px solid var(--phosphor-dim);
    /* Default (cw4 cream): dark text on phosphor */
    color: #08090f;
    background: var(--phosphor);
    transition: color 0.2s ease, background 0.2s ease;
  }

  /* When cw2 photo is revealed, flip back to phosphor-on-dark */
  .portrait-wrap:hover .portrait-label,
  .portrait-wrap.flipped .portrait-label {
    color: var(--phosphor);
    background: rgba(0, 0, 0, 0.6);
  }

  /* Default (cw4 cream): dark wedges in the photo corners */
  .portrait-wrap .corner.tl { border-top-color: #08090f; border-left-color: #08090f; }
  .portrait-wrap .corner.tr { border-top-color: #08090f; border-right-color: #08090f; }
  .portrait-wrap .corner.bl { border-bottom-color: #08090f; border-left-color: #08090f; }
  .portrait-wrap .corner.br { border-bottom-color: #08090f; border-right-color: #08090f; }

  /* When cw2 is revealed, wedges go back to phosphor */
  .portrait-wrap:hover .corner,
  .portrait-wrap.flipped .corner {
    border-color: var(--phosphor) !important;
  }

  .corner {
    position: absolute;
    width: 10px;
    height: 10px;
    z-index: 2;
  }

  .corner.tl { top: 7px;    left: 7px;   border-top:    1px solid var(--phosphor); border-left:   1px solid var(--phosphor); }
  .corner.tr { top: 7px;    right: 7px;  border-top:    1px solid var(--phosphor); border-right:  1px solid var(--phosphor); }
  .corner.bl { bottom: 7px;  left: 7px;  border-bottom: 1px solid var(--phosphor); border-left:   1px solid var(--phosphor); }
  .corner.br { bottom: 7px;  right: 7px; border-bottom: 1px solid var(--phosphor); border-right:  1px solid var(--phosphor); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--sp-2xl);
    align-items: start;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  .about-lead {
    font-size: 1.1rem;
    color: var(--fg);
    max-width: 55ch;
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
    padding-top: 0.25rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-block {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .sidebar-list li {
    font-size: 0.85rem;
    color: var(--fg-muted);
    padding-left: var(--sp-sm);
    border-left: 1px solid var(--border);
  }

  .sidebar-note {
    font-size: 0.82rem;
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: none;
  }

  .sidebar-link {
    font-size: 0.85rem;
    color: var(--phosphor);
    letter-spacing: 0.08em;
  }

  .portrait-mobile {
    display: none;
  }

  @media (min-width: 769px) {
    .section {
      padding-top: var(--sp-lg);
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: var(--sp-md) 0 var(--sp-sm);
    }

    .section {
      padding-top: var(--sp-lg);
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
    }

    .about-sidebar {
      position: static;
    }

    .portrait-sidebar {
      display: none;
    }

    .portrait-mobile {
      display: block;
      float: right;
      width: 50%;
      margin: 5px 0 0.75rem 1.25rem;
    }

    .about-intro::after {
      content: '';
      display: table;
      clear: both;
    }
  }
</style>

<script>
  let flipping = false;

  document.querySelectorAll('.portrait-glitch-container').forEach((container) => {
    // Click to flip with animation
    container.addEventListener('click', () => {
      if (flipping) return;
      flipping = true;

      const wraps = document.querySelectorAll('.portrait-wrap');
      const willFlip = !wraps[0].classList.contains('flipped');

      // Phase 1: collapse
      wraps.forEach((w) => w.classList.add('flipping'));

      setTimeout(() => {
        // Phase 2: swap at midpoint
        wraps.forEach((w) => w.classList.toggle('flipped', willFlip));

        // Phase 3: expand
        requestAnimationFrame(() => {
          wraps.forEach((w) => w.classList.remove('flipping'));
          setTimeout(() => { flipping = false; }, 300);
        });
      }, 300);
    });

    // Track mouse for band mask
    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width * 100).toFixed(1) + '%';
      const y = ((e.clientY - rect.top) / rect.height * 100).toFixed(1) + '%';
      const wrap = container.closest('.portrait-wrap');
      if (wrap) {
        wrap.style.setProperty('--mx', x);
        wrap.style.setProperty('--my', y);
      }
    });
  });
</script>
