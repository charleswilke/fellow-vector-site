---
import CRTIntro from '../components/CRTIntro.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fellow Vector',
  description = 'Consulting, speaking, and strategic guidance for businesses and leaders navigating the AI era.',
} = Astro.props;

const siteUrl = 'https://fellowvector.com';
const ogTitle = title === 'Fellow Vector' ? title : `${title} — Fellow Vector`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{ogTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Fellow Vector" />
    <meta property="og:title"       content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}/og.jpg`} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url"         content={siteUrl} />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}/og.jpg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <CRTIntro />
    <Nav />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  #main-content {
    padding-top: 64px; /* nav height */
  }
</style>
